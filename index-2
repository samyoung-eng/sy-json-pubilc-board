<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>정적 JSON 게시판</title>

  <style>
    body {
      font-family: '맑은 고딕', sans-serif;
      padding: 1rem;
      margin: 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
      margin-top: 1rem;
    }

    th, td {
      border: 1px solid #ccc;
      padding: 0.5rem;
      text-align: left;
      word-wrap: break-word;
    }

    th {
      background-color: #f2f2f2;
      text-align: center;
    }

    #searchInput {
      display: none !important;
    }

    #pagination {
      margin-top: 1rem;
      text-align: center;
    }

    #pagination button {
      margin: 0 3px;
      width: 42px;
      height: 42px;
      padding: 0;
      text-align: center;
      font-size: 14px;
      border: 1px solid #ccc;
      border-radius: 4px;
      background: #fff;
      color: #000;
      box-sizing: border-box;
      vertical-align: middle;
      cursor: pointer;
      transition: background-color 0.3s, color 0.3s;
    }

    #pagination button.active {
      background-color: #b12221 !important;
      color: #fff !important;
      border-color: #b12221 !important;
    }

    #pagination button:hover:not(:disabled) {
      background-color: #b12221 !important;
      color: #fff !important;
      border-color: #b12221 !important;
    }

    #pagination button:disabled {
      cursor: default;
      opacity: 0.5;
    }

    /* 열 비율 조정 */
    table th:nth-child(1),
    table td:nth-child(1) {
      width: 15%;
      text-align: center;
    }

    table th:nth-child(2),
    table td:nth-child(2) {
      width: 5%;
      text-align: center;
    }

    table th:nth-child(3),
    table td:nth-child(3) {
      width: 30%;
    }

    table th:nth-child(4),
    table td:nth-child(4) {
      width: 45%;
    }

    /* 모바일 카드형 */
    @media (max-width: 768px) {
      table.project-table,
      table.project-table thead,
      table.project-table tbody,
      table.project-table th,
      table.project-table td,
      table.project-table tr {
        display: block;
        width: 100%;
      }

      table.project-table thead {
        display: none;
      }

      table.project-table tbody tr {
        border: 1px solid #ccc;
        border-radius: 8px;
        padding: 12px;
        margin-bottom: 16px;
        background: #fff;
      }

      table.project-table tbody td {
        border: none;
        padding: 4px 0;
        text-align: left !important;
        font-size: 14px;
        position: relative;
      }

      table.project-table tbody td:nth-child(1) {
        font-weight: bold;
        font-size: 15px;
        margin-bottom: 6px;
      }

      table.project-table tbody td:not(:first-child)::before {
        content: attr(data-label);
        font-weight: bold;
        display: block;
        color: #777;
        margin-bottom: 2px;
      }
    }
  </style>
</head>
<body>

  <input
    id="searchInput"
    oninput="renderTable()"
    placeholder="검색어를 입력하세요"
    style="margin-top:10px; padding:5px; width:100%; max-width:300px;"
    type="text"
  />

  <table class="project-table">
    <colgroup>
      <col style="width: 15%;" />
      <col style="width: 5%;" />
      <col style="width: 30%;" />
      <col style="width: 45%;" />
    </colgroup>
    <thead>
      <tr>
        <th>구분</th>
        <th>시공년도</th>
        <th>발주처</th>
        <th>공사내용</th>
      </tr>
    </thead>
    <tbody id="dataBody"></tbody>
  </table>

  <div id="pagination"></div>

  <script>
    let rawData = [];
    let currentPage = 1;
    const rowsPerPage = 20;
    let currentFilter = '전체';

    function renderTable() {
      const keyword = document.getElementById('searchInput').value.toLowerCase();

      const filtered = rawData.filter(row => {
        const matchSearch = Object.values(row).some(val =>
          String(val).toLowerCase().includes(keyword)
        );
        return matchSearch;
      });

      const total = filtered.length;
      const pages = Math.ceil(total / rowsPerPage);
      const tbody = document.getElementById('dataBody');
      tbody.innerHTML = '';

      const expectedKeys = ['구분', '시공년도', '발주처', '공사내용'];

      filtered
        .slice((currentPage - 1) * rowsPerPage, currentPage * rowsPerPage)
        .forEach(row => {
          const tr = document.createElement('tr');

          expectedKeys.forEach(key => {
            const td = document.createElement('td');
            td.textContent = row[key] || '';
            td.setAttribute('data-label', key);
            tr.appendChild(td);
          });

          tbody.appendChild(tr);
        });

      const pag = document.getElementById('pagination');
      pag.innerHTML = '';

      if (total > rowsPerPage) {
        const maxPageButtons = 10;
        const pageGroupIndex = Math.floor((currentPage - 1) / maxPageButtons);
        const startPage = pageGroupIndex * maxPageButtons + 1;
        const endPage = Math.min(startPage + maxPageButtons - 1, pages);

        const first = document.createElement('button');
        first.textContent = '⏮';
        first.disabled = currentPage === 1;
        first.onclick = () => {
          currentPage = 1;
          renderTable();
        };
        pag.appendChild(first);

        const prev = document.createElement('button');
        prev.textContent = '◀';
        prev.disabled = startPage === 1;
        prev.onclick = () => {
          if (startPage > 1) {
            currentPage = startPage - maxPageButtons;
            renderTable();
          }
        };
        pag.appendChild(prev);

        for (let i = startPage; i <= endPage; i++) {
          const btn = document.createElement('button');
          btn.textContent = i;

          if (i === currentPage) {
            btn.classList.add('active');
          }

          btn.onclick = () => {
            currentPage = i;
            renderTable();
          };

          pag.appendChild(btn);
        }

        const next = document.createElement('button');
        next.textContent = '▶';
        next.disabled = endPage >= pages;
        next.onclick = () => {
          if (endPage < pages) {
            currentPage = endPage + 1;
            renderTable();
          }
        };
        pag.appendChild(next);

        const last = document.createElement('button');
        last.textContent = '⏭';
        last.disabled = currentPage === pages;
        last.onclick = () => {
          currentPage = pages;
          renderTable();
        };
        pag.appendChild(last);
      }
    }

    window.onload = () => {
      fetch("https://samyoung-eng.github.io/sy-json-pubilc-board/projectData.json")
        .then(res => res.json())
        .then(data => {
          rawData = data;
          currentPage = 1;
          renderTable();
        })
        .catch(err => {
          console.error("데이터 로드 실패:", err);
          document.getElementById("dataBody").innerHTML =
            "<tr><td colspan='4' style='text-align:center; color:red;'>데이터를 불러올 수 없습니다.</td></tr>";
        });
    };
  </script>

</body>
</html>
